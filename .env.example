# Compressor — Configuration (copier en .env pour personnaliser)

# Mode debug pywebview (outils de dev)
# COMPRESSOR_DEBUG=false

# Plage de ports pour le serveur Flask local
# COMPRESSOR_PORT_START=5050
# COMPRESSOR_PORT_END=5060

# Chemin vers terminal-notifier (notifications macOS)
# COMPRESSOR_NOTIFIER=/opt/homebrew/bin/terminal-notifier

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
# COMPRESSOR_LOG_LEVEL=INFO
